<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    
    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>INFO: %d{yyyy-MM-dd HH:mm:ss} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <!-- File Appender for test execution logs -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>target/test-execution.log</file>
        <append>false</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <!-- Root logger configuration - set to WARN to suppress most logs -->
    <root level="WARN">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
    
    <!-- Specific logger for test results - INFO level to show test status -->
    <logger name="com.api.listeners.TestResultLogger" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>
    
    <!-- Specific logger for base test setup - INFO level -->
    <logger name="com.api.base.BaseTest" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </logger>
    
    <!-- Suppress REST Assured logging completely -->
    <logger name="io.restassured" level="OFF" />
    <logger name="io.restassured.filter.log" level="OFF" />
    <logger name="org.apache.http" level="OFF" />
    <logger name="org.apache.http.wire" level="OFF" />
    <logger name="org.apache.http.headers" level="OFF" />
    
</configuration>
